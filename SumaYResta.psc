Algoritmo SumaYResta
	Definir NumeroUno, NumeroDos, resultado, resultado2 Como Entero
	Escribir "Ingrese el primer numero"
	leer NumeroUno
	Escribir "Ingrese el segundo numero"
	leer NumeroDos
	
	resultado = NumeroUno - NumeroDos
	Escribir "el resultado es igual a ", resultado
	
	
	resultado2 = NumeroUno + NumeroDos
	Escribir "el resultado es igual a ", resultado2

FinAlgoritmo
